# Environment Configuration Example
# Copy this to .env for local development

# Flask Configuration
FLASK_ENV=development
SECRET_KEY=your-secret-key-here-change-in-production

# Database Configuration
# For local development (SQLite - default if not set)
# DATABASE_URL=sqlite:///pencil2pixel.db

# For production (PostgreSQL - Leapcell will provide this)
# DATABASE_URL=postgresql+psycopg2://user:password@host:port/database?sslmode=require
